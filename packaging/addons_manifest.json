{
  "schema_version": 1,
  "addons_root": "addons",
  "notes": "Optional downloadable packs live under addons/<id>/. Deleting a folder + reconcile restores fresh-extract state for that pack.",
  "addons": [
    {
      "id": "face_puppeteer",
      "folder": "face_puppeteer",
      "label": "Face puppeteer runtime (PyTorch + wx + MediaPipe)",
      "size_hint_mb": 3500,
      "required_for": ["tha4_student_face_capture_mediapipe"],
      "delete_safe": true,
      "included_in_github_zip": false,
      "install_via": ["bootstrap_portable.ps1", "upstream:mediapipe_task"],
      "verify": [
        "addons/face_puppeteer/venv/Scripts/python.exe",
        "addons/face_puppeteer/mediapipe/face_landmarker_v2_with_blendshapes.task"
      ]
    },
    {
      "id": "openseeface",
      "folder": "openseeface",
      "label": "OpenSeeFace facetracker binary + models",
      "size_hint_mb": 200,
      "required_for": ["tha4_student_face_capture_openseeface"],
      "delete_safe": true,
      "included_in_github_zip": false,
      "install_via": ["upstream:openseeface"],
      "verify": [
        "addons/openseeface/Binary/facetracker.exe"
      ]
    },
    {
      "id": "tha3_models",
      "folder": "tha3_models",
      "label": "THA3 portrait PyTorch models (~2 GB)",
      "size_hint_mb": 2000,
      "required_for": ["tha3_portrait"],
      "delete_safe": true,
      "included_in_github_zip": false,
      "install_via": ["upstream:tha3_models"],
      "verify": [
        "addons/tha3_models/separable_half/face_morpher.pt",
        "addons/tha3_models/separable_half/editor.pt"
      ]
    },
    {
      "id": "tha4_training",
      "folder": "tha4_training",
      "label": "THA4 teacher weights + pose dataset (training / distill)",
      "size_hint_mb": 2500,
      "required_for": ["tha4_train"],
      "delete_safe": true,
      "included_in_github_zip": false,
      "install_via": ["upstream:tha4_teacher_training"],
      "verify": [
        "addons/tha4_training/tha4/face_morpher.pt",
        "addons/tha4_training/pose_dataset.pt"
      ]
    },
    {
      "id": "output_enhancement",
      "folder": "output_enhancement",
      "label": "Output enhancement (NN SR + RIFE ONNX + onnxruntime)",
      "size_hint_mb": 800,
      "required_for": ["nn_super_resolution", "nn_rife"],
      "delete_safe": true,
      "included_in_github_zip": false,
      "install_via": ["bootstrap_output_enhancement.ps1"],
      "verify": [
        "addons/output_enhancement/.installed",
        "addons/output_enhancement/ezvtb_data/rife/rife_x2_fp32.onnx",
        "addons/output_enhancement/ezvtb_data/waifu2x/noise0_scale2x_fp32.onnx",
        "addons/output_enhancement/ezvtb_data/Real-ESRGAN/exported_256_fp32.onnx"
      ]
    }
  ]
}
